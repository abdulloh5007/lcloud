# Copy to .env.docker before docker compose up.
# Telegram API credentials: https://my.telegram.org/apps
TG_API_ID=0
TG_API_HASH=

# 0 = bootstrap mode. First successful Telegram phone+code login claims admin.
LC_ADMIN_TG_ID=0

# Container bind address. Do not change unless you know why.
LC_HOST=0.0.0.0
LC_PORT=8787

# Public URL users and SDKs will open.
LC_PUBLIC_BASE_URL=https://your-domain.com

# true behind HTTPS reverse proxy. Use false for direct http://IP:8787 testing.
LC_COOKIE_SECURE=true

# Browser origins allowed to call public DB/storage from another site.
# Example: https://your-site.com,https://www.your-site.com
LC_CORS_ALLOW_ORIGINS=

# Persistent paths inside the mounted ./data volume.
LC_DATA_DIR=/app/data
LC_SESSION_FILE=/app/data/session.lcloud
LC_DB_URL=sqlite+aiosqlite:////app/data/lcloud.db

# Runtime limits.
LC_MAX_FILE_BYTES=1073741824
LC_MAX_WORKERS=10
LC_MTPROTO_RATE_PER_SEC=20
LC_MTPROTO_BURST=20
LC_MTPROTO_MAX_FLOODWAIT_SEC=300

# JSON DB Telegram backup.
LC_JSON_DB_BACKUP_ENABLED=true
LC_JSON_DB_BACKUP_INTERVAL_SECONDS=5
LC_JSON_DB_BACKUP_BATCH_OPERATIONS=250
