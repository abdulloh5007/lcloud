# Telegram API credentials — get from https://my.telegram.org/apps
TG_API_ID=0
TG_API_HASH=

# Admin Telegram ID. Set 0 for bootstrap mode (first phone+code login claims it
# and writes data/keys/admin.tgid stamp). Once set, env wins over stamp.
LC_ADMIN_TG_ID=0

# Network: bind host (0.0.0.0 in container, 127.0.0.1 + nginx for prod)
LC_HOST=127.0.0.1
LC_PORT=8787

# Public base URL — used in magic-link emails / API key prefixes
LC_PUBLIC_BASE_URL=https://example.com

# Cookie security flags
LC_COOKIE_SECURE=true
