{
  "name": "@lcloud/db",
  "version": "0.1.12",
  "description": "TypeScript client for LCloud DB JSON document collections.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./clients": {
      "types": "./dist/clients/index.d.ts",
      "import": "./dist/clients/index.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./refs": {
      "types": "./dist/refs/index.d.ts",
      "import": "./dist/refs/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abdulloh5007/lcloud.git",
    "directory": "sdk"
  },
  "bugs": {
    "url": "https://github.com/abdulloh5007/lcloud/issues"
  },
  "homepage": "https://github.com/abdulloh5007/lcloud#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "pack:check": "npm pack --dry-run"
  },
  "keywords": [
    "lcloud",
    "database",
    "json",
    "document-database",
    "telegram",
    "firebase",
    "supabase"
  ],
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.10.2"
  },
  "bin": {
    "lcloud-db": "dist/cli.js"
  }
}
